=== import busio
import digitalio
import microcontroller

SCK = microcontroller.pin.PA05
MOSI = microcontroller.pin.PA07
MISO = microcontroller.pin.PA06
CS_PIN = microcontroller.pin.PE10

READ_CMD_CHIP = 0x80

def probe(pol, ph, cs_active_low):
    spi = busio.SPI(SCK, MOSI=MOSI, MISO=MISO)
    cs = digitalio.DigitalInOut(CS_PIN)
    cs.direction = digitalio.Direction.OUTPUT
    cs.value = True if cs_active_low else False
    print("CSPROBE_START pol={} ph={} cs_low={}".format(pol, ph, int(cs_active_low)))
    try:
        outb = bytearray(3)
        inb = bytearray(3)
        outb[0] = READ_CMD_CHIP
        for i in range(20):
            while not spi.try_lock():
                pass
            try:
                spi.configure(baudrate=1600, polarity=pol, phase=ph)
                cs.value = False if cs_active_low else True
                spi.write_readinto(outb, inb)
                cs.value = True if cs_active_low else False
            finally:
                spi.unlock()
            print("i={} in={}".format(i, ["0x{:02X}".format(x) for x in inb]))
    finally:
        cs.deinit(); spi.deinit(); print("CSPROBE_DONE")

probe(0,0,True)
probe(0,0,False)
probe(1,1,True)
probe(1,1,False)
