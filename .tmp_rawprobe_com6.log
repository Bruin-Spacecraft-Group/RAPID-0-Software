=== import busio
import digitalio
import microcontroller

SCK = microcontroller.pin.PA05
MOSI = microcontroller.pin.PA07
MISO = microcontroller.pin.PA06
CS_PIN = microcontroller.pin.PE10

READ_CMD_CHIP = 0x80

def probe(pol, ph):
    spi = busio.SPI(SCK, MOSI=MOSI, MISO=MISO)
    cs = digitalio.DigitalInOut(CS_PIN)
    cs.direction = digitalio.Direction.OUTPUT
    cs.value = True
    print("RAW_PROBE_START pol={} ph={}".format(pol, ph))
    try:
        for n in (2,3,4,5,6,7,8):
            outb = bytearray(n)
            inb = bytearray(n)
            outb[0] = READ_CMD_CHIP
            # repeat multiple times
            row = []
            for _ in range(6):
                while not spi.try_lock():
                    pass
                try:
                    spi.configure(baudrate=1600, polarity=pol, phase=ph)
                    cs.value = False
                    spi.write_readinto(outb, inb)
                    cs.value = True
                finally:
                    spi.unlock()
                row.append('[' + ' '.join('0x{:02X}'.format(x) for x in inb) + ']')
            print("N={} {}".format(n, ' '.join(row)))
    finally:
        cs.deinit()
        spi.deinit()
        print("RAW_PROBE_DONE pol={} ph={}".format(pol, ph))

probe(0,0)
probe(1,1)
